{
  "name": "i0c.cc-workspace",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Revaea/i0c.cc.git"
  },
  "homepage": "https://github.com/Revaea/i0c.cc",
  "packageManager": "pnpm@11.17.0+sha512.cca3cea332ad254bb84145f966d19f4879615210346fc92c79a047f23a0d7b3cca3c3792f0076ba1f1831d277efbcf0a9119b31a9a60eca7fb3d6231f331ef72",
  "scripts": {
    "check": "pnpm config:check && pnpm plugins:check && pnpm runtime:check && pnpm runtime:test && pnpm runtime:build && pnpm webui:test && pnpm webui:lint && pnpm webui:build",
    "config:check": "pnpm --filter @i0c/config check",
    "plugins:check": "pnpm --filter @i0c/analytics-domain check && pnpm --filter @i0c/plugin-api check && pnpm --filter @i0c/plugin-testkit check && pnpm --filter @i0c/plugin-testkit test && pnpm --filter @i0c/plugin-catalog check && pnpm --filter @i0c/plugin-catalog test && pnpm --filter @i0c/runtime-build check && pnpm --filter @i0c/runtime-build test && pnpm --filter @i0c/runtime-host check && pnpm --filter @i0c/runtime-host test && pnpm --filter @i0c/runtime-fixture-external check && pnpm --filter @i0c/runtime-fixture-external test && pnpm --workspace-concurrency=1 --filter \"./plugins/**\" check && pnpm --workspace-concurrency=1 --filter \"./plugins/**\" test && pnpm plugins:boundaries",
    "plugins:boundaries": "node packages/plugin-testkit/scripts/check-boundaries.mjs",
    "runtime:check": "pnpm --filter i0c-redirect-worker check",
    "runtime:test": "pnpm --filter i0c-redirect-worker test",
    "runtime:build": "pnpm --filter i0c-redirect-worker build",
    "runtime:build:cf": "pnpm --filter i0c-redirect-worker build:cf",
    "runtime:dev:cf": "pnpm --filter i0c-redirect-worker dev:cf",
    "runtime:deploy:cf": "pnpm --filter i0c-redirect-worker deploy:cf",
    "runtime:build:vc": "pnpm --filter i0c-redirect-worker build:vc",
    "runtime:dev:vc": "pnpm --filter i0c-redirect-worker dev:vc",
    "runtime:deploy:vc": "pnpm --filter i0c-redirect-worker deploy:vc",
    "runtime:build:nf": "pnpm --filter i0c-redirect-worker build:nf",
    "runtime:dev:nf": "pnpm --filter i0c-redirect-worker dev:nf",
    "runtime:deploy:nf": "pnpm --filter i0c-redirect-worker deploy:nf",
    "webui:dev": "pnpm --filter i0c.cc-webui dev",
    "webui:build": "pnpm --filter i0c.cc-webui build",
    "webui:test": "pnpm --filter i0c.cc-webui test",
    "webui:start": "pnpm --filter i0c.cc-webui start",
    "webui:lint": "pnpm --filter i0c.cc-webui lint",
    "analytics:migrate": "pnpm --filter i0c.cc-webui analytics:migrate",
    "data:validate": "pnpm --filter i0c.cc-webui validate:data-config && pnpm --filter i0c.cc-webui validate:redirects"
  },
  "devDependencies": {
    "@i0c/analytics-domain": "workspace:*",
    "@i0c/config": "workspace:*",
    "@i0c/plugin-analytics-sink-http": "workspace:*",
    "@i0c/plugin-analytics-store-d1": "workspace:*",
    "@i0c/plugin-analytics-store-postgres": "workspace:*",
    "@i0c/plugin-api": "workspace:*",
    "@i0c/plugin-feature-bot-classifier": "workspace:*",
    "@i0c/plugin-github-data": "workspace:*",
    "@i0c/plugin-runtime-cloudflare": "workspace:*",
    "@i0c/plugin-runtime-netlify": "workspace:*",
    "@i0c/plugin-runtime-vercel": "workspace:*",
    "@i0c/runtime-build": "workspace:*",
    "@i0c/runtime-fixture-external": "workspace:*",
    "@i0c/runtime-host": "workspace:*"
  }
}
