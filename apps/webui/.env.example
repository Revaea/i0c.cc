# [EN] Non-sensitive application settings are loaded from data/config.json.
# [CN] 应用非敏感配置从 data/config.json 加载。

# [EN] GitHub OAuth is required. Callback URL: <NEXTAUTH_URL>/api/auth/callback/github
# [CN] GitHub OAuth 为必填项。回调地址：<NEXTAUTH_URL>/api/auth/callback/github
GITHUB_CLIENT_ID="your-client-id"
GITHUB_CLIENT_SECRET="your-client-secret"

# [EN] NextAuth is required. Use an independent random secret of at least 32 characters.
# [CN] NextAuth 为必填项。使用至少 32 字符的独立随机密钥。
# [EN] Do not reuse GitHub, database, or analytics credentials.
# [CN] 不要复用 GitHub、数据库或统计凭据。
NEXTAUTH_SECRET="replace-with-a-32-byte-random-secret"
# [EN] Use http://localhost:3000 locally and https://u.i0c.cc in production.
# [CN] 本地开发使用 http://localhost:3000，生产环境使用 https://u.i0c.cc。
NEXTAUTH_URL="http://localhost:3000"

# [EN] Short-link analytics are optional. The database must support PostgreSQL with TLS.
# [CN] 短链接统计为可选功能。数据库必须兼容 PostgreSQL 并启用 TLS。
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"
# [EN] Use an independent random secret of at least 32 characters and set every Runtime
# [CN] 使用至少 32 字符的独立随机密钥，并在每套 Runtime 中将
# [EN] ANALYTICS_WRITE_KEY to the exact same value. Never add the NEXT_PUBLIC_ prefix.
# [CN] ANALYTICS_WRITE_KEY 设为完全相同的值。不得添加 NEXT_PUBLIC_ 前缀。
ANALYTICS_INGEST_SECRET="replace-with-a-32-byte-random-secret"
# [EN] Vercel Cron calls the retention endpoint daily. Use a separate random secret.
# [CN] Vercel Cron 每天调用数据保留端点。使用独立随机密钥，不要复用其他凭据。
CRON_SECRET="replace-with-a-32-byte-random-secret"
