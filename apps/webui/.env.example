# GitHub OAuth（必填）
# OAuth callback URL：<NEXTAUTH_URL>/api/auth/callback/github
GITHUB_CLIENT_ID="your-client-id"
GITHUB_CLIENT_SECRET="your-client-secret"
# 公共仓库使用 public_repo；私有仓库改为 repo。
GITHUB_OAUTH_SCOPE="read:user user:email public_repo"

# WebUI 访问模式（必填）：
# authenticated 允许任意 GitHub 用户登录并管理编辑；allowlist 仅允许指定数字用户 ID；
# public-readonly 允许任意 GitHub 用户只读查看，名单内用户登录后可管理编辑。
WEBUI_ACCESS_MODE="authenticated"
# allowlist 模式下必填；public-readonly 模式下选填，名单内用户可登录管理。
# 使用英文逗号分隔多个 GitHub 数字用户 ID。
GITHUB_ALLOWED_USER_IDS=""

# NextAuth（必填）
# 使用至少 32 字符的独立随机密钥，不要与 GitHub、数据库或统计密钥共用。
NEXTAUTH_SECRET="replace-with-a-32-byte-random-secret"
# 本地开发使用 http://localhost:3000；生产环境填写 https://u.i0c.cc。
NEXTAUTH_URL="http://localhost:3000"

# 重定向数据仓库（必填）
GITHUB_REPO_OWNER="Revaea"
GITHUB_REPO_NAME="i0c.cc"
GITHUB_TARGET_BRANCH="data"
GITHUB_CONFIG_PATH="redirects.json"

# 二维码与短链接预览使用的 Runtime 公开地址。该变量会暴露给浏览器，不能写密钥。
NEXT_PUBLIC_DOMAIN="https://i0c.cc"

# 短链接统计（可选）
# 数据库必须兼容标准 PostgreSQL 并启用 TLS。
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"
# 统计功能还要求下面两项同时有效。
# 使用至少 32 字符的独立随机密钥，并在每套 Runtime 中将
# ANALYTICS_WRITE_KEY 设置为完全相同的值。不要添加 NEXT_PUBLIC_ 前缀。
ANALYTICS_INGEST_SECRET="replace-with-a-32-byte-random-secret"
# 使用小写基础域名作为统计命名空间，并与所有 Runtime 的值完全一致。
# 该域名及其子域名会分别统计，命名空间之外的域名归为 unknown。
ANALYTICS_SOURCE_ID="i0c.cc"
# Vercel Cron 每天调用统计清理端点。使用独立的随机密钥，不要复用其他凭据。
CRON_SECRET="replace-with-a-32-byte-random-secret"
