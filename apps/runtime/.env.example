# Redirect data source
REDIRECTS_CONFIG_REPO="Revaea/i0c.cc"
REDIRECTS_CONFIG_BRANCH="data"
REDIRECTS_CONFIG_PATH="redirects.json"

# Optional: use a full URL instead of repo/branch/path.
# REDIRECTS_CONFIG_URL="https://raw.githubusercontent.com/Revaea/i0c.cc/data/redirects.json"

# Optional: set to "allow" to publish an open robots.txt.
# ROBOTS_POLICY="allow"

# Optional analytics collector. All three values are required to enable event delivery.
# ANALYTICS_ENDPOINT="https://panel.example.com/api/analytics/events"
# ANALYTICS_WRITE_KEY="replace-with-a-long-random-secret"
# ANALYTICS_SOURCE_ID="i0c.cc"
