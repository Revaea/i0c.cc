# Redirect data source. These three values are used together.
REDIRECTS_CONFIG_REPO="Revaea/i0c.cc"
REDIRECTS_CONFIG_BRANCH="data"
REDIRECTS_CONFIG_PATH="redirects.json"

# Optional alternative to the repository settings above. Keep it empty to use them.
REDIRECTS_CONFIG_URL=""

# Crawler policy. Set it to "allow" to publish an open robots.txt.
ROBOTS_POLICY="allow"

# Privacy-preserving analytics delivery.
# Replace the secret before deployment. Analytics remains disabled unless all
# three values below are valid.
# Use the WebUI collector route. HTTPS is required outside local loopback development.
ANALYTICS_ENDPOINT="https://u.i0c.cc/api/analytics/events"
# Use a random secret of at least 32 characters. It must exactly match the WebUI
# ANALYTICS_INGEST_SECRET and must be different from auth or database credentials.
ANALYTICS_WRITE_KEY="replace-with-a-32-byte-random-secret"
# Use the lowercase base hostname as one stable source namespace across all
# providers. Its subdomains are reported separately without another domain list.
ANALYTICS_SOURCE_ID="i0c.cc"
