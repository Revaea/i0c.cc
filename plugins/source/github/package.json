  "dependencies": {
    "@i0c/config": "workspace:*",
    "@i0c/plugin-api": "workspace:*"
  },
  "devDependencies": {
    "@i0c/plugin-testkit": "workspace:*",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
