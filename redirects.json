{
  "$schema": "https://raw.githubusercontent.com/IGCyukira/i0c.cc/main/redirects.schema.json",
  "Slots": {
    "Main": {
      "/": {
        "type": "proxy",
        "appendPath": true,
        "target": "https://api.revaea.com"
      },
      "/r": {
        "type": "prefix",
        "appendPath": true,
        "status": 302,
        "target": "https://revaea.com"
      },
      "/i": {
        "type": "prefix",
        "appendPath": false,
        "status": 302,
        "target": "https://revaea.com/igcrystal"
      },
      "/i/b": {
        "type": "exact",
        "target": "https://blog.igcrystal.icu",
        "status": 302
      }
    },
    "Others": {
      "/r/h": {
        "type": "prefix",
        "appendPath": true,
        "status": 302,
        "target": "https://hls.revaea.com"
      },
      "/r/p": {
        "type": "proxy",
        "appendPath": true,
        "target": "https://i.pximg.net"
      },
      "/r/c": {
        "type": "prefix",
        "appendPath": true,
        "target": "https://c.revaea.com",
        "status": "302"
      },
      "/r/n": {
        "type": "prefix",
        "appendPath": true,
        "status": "302",
        "target": "https://n.revaea.com"
      },
      "/r/g": {
        "type": "proxy",
        "appendPath": true,
        "target": "https://raw.githubusercontent.com"
      }
    }
  }
}