{
  "$schema": "https://raw.githubusercontent.com/Revaea/i0c.cc/main/apps/runtime/redirects.schema.json",
  "Slots": {
    "Main": {
      "/": {
        "type": "proxy",
        "appendPath": true,
        "target": "https://api.revaea.com"
      },
      "/r": {
        "type": "prefix",
        "appendPath": true,
        "status": 302,
        "target": "https://revaea.com"
      }
    },
    "Others": {
      "/r/h": {
        "type": "prefix",
        "appendPath": true,
        "status": 302,
        "target": "https://hls.revaea.com"
      },
      "/r/p": {
        "type": "proxy",
        "appendPath": true,
        "target": "https://i.pximg.net"
      },
      "/r/g": {
        "type": "proxy",
        "appendPath": true,
        "target": "https://raw.githubusercontent.com"
      }
    }
  }
}